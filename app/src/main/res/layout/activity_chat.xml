<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_secondary_button"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="返回"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI SURVIVAL CHAT"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 生存聊天"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonModels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_secondary_button"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="模型"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_chip"
        android:padding="12dp"
        android:text="@string/ai_disclaimer"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:clipToPadding="false"
        android:padding="12dp" />

    <LinearLayout
        android:id="@+id/layoutSelectedImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_image_preview"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imageSelectedPreview"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="已附加图片，发送后会结合图片内容进行本地推理。"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/buttonClearImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_secondary_button"
            android:minWidth="0dp"
            android:text="移除"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/buttonImage"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_secondary_button"
            android:contentDescription="上传图片"
            android:padding="12dp"
            android:src="@drawable/ic_image_add"
            android:tint="@null" />

        <EditText
            android:id="@+id/inputQuestion"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:hint="输入你的处境，或只上传图片"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/buttonSend"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_primary_button"
            android:contentDescription="发送"
            android:padding="14dp"
            android:src="@drawable/ic_send"
            android:tint="@null" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_secondary_button"
        android:text="清空对话"
        android:textColor="@color/text_primary" />
</LinearLayout>
